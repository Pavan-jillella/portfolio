# Environment Variables
# Copy this file to .env.local and fill in the values

# ── Site ──
SITE_URL=https://your-domain.vercel.app

# ── Supabase (required for auth + data) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub API (for fetching repos on /projects) ──
GITHUB_TOKEN=

# ── LeetCode stats ──
LEETCODE_USERNAME=Punisher_17

# ── SMTP / Nodemailer (for contact form) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=

# ── Auth ──
AUTH_PIN=

# ── AI (OpenRouter preferred, falls back to OpenAI) ──
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ── Cloudflare Turnstile (CAPTCHA, optional) ──
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Sentry (error tracking, optional) ──
NEXT_PUBLIC_SENTRY_DSN=

# ── PostHog (analytics, optional) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Cron Jobs (optional) ──
CRON_SECRET=

# ── Admin (optional) ──
OWNER_EMAIL=
NEXT_PUBLIC_OWNER_EMAIL=
