# Environment Variables
# Copy this file to .env.local and fill in the values

# GitHub API - for fetching repositories
GITHUB_TOKEN=

# LeetCode - username for stats
LEETCODE_USERNAME=Punisher_17

# SMTP (Nodemailer) - for contact form
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=

# Supabase - for auth, comments, newsletter, analytics
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI - for AI chatbot
OPENAI_API_KEY=
